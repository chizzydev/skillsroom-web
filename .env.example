# Skill Rooms web environment
# Copy this file to .env, then fill the required values.

# Required local URLs
NEXT_PUBLIC_APP_URL=http://localhost:3100
NEXT_PUBLIC_API_BASE_URL=http://localhost:4100

# Optional auth app override
# Leave empty while Skill Rooms owns auth inside this web app.
AUTH_APP_URL=

# Admin UI behavior mirror
# Keep aligned with the API ADMIN_STEP_UP_REQUIRED value.
ADMIN_STEP_UP_REQUIRED=false

# Optional Google sign-in
# Required only if Google sign up/sign in/linking should render.
# This must match the API GOOGLE_CLIENT_ID value.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional Search Console URL-prefix verification token
GOOGLE_SITE_VERIFICATION=

# Evidence storage
# Use local only for localhost development.
EVIDENCE_STORAGE_PROVIDER=local

# Generic S3-compatible production storage
EVIDENCE_S3_BUCKET=
EVIDENCE_S3_REGION=
EVIDENCE_S3_ENDPOINT=
EVIDENCE_S3_ACCESS_KEY_ID=
EVIDENCE_S3_SECRET_ACCESS_KEY=
EVIDENCE_S3_PREFIX=
EVIDENCE_S3_FORCE_PATH_STYLE=false

# Cloudflare R2 production storage
EVIDENCE_R2_ACCOUNT_ID=
EVIDENCE_R2_BUCKET=
EVIDENCE_R2_ACCESS_KEY_ID=
EVIDENCE_R2_SECRET_ACCESS_KEY=
EVIDENCE_R2_PREFIX=
EVIDENCE_R2_FORCE_PATH_STYLE=false
